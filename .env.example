# ─── Base de datos ──────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lifequest"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/lifequest"

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-un-secreto-de-minimo-32-caracteres"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="otro-secreto-diferente-minimo-32-caracteres"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ─── Servidor ───────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"

# ─── Web Push (generar con: npx web-push generate-vapid-keys) ──
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@lifequest.app"

# ─── IA — Google Gemini 2.0 Flash (gratis en aistudio.google.com/app/apikey) ──
GEMINI_API_KEY=""

# ─── Integraciones OAuth ──────────────────────────────────
# Spotify — Configurar en https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://localhost:3001/api/v1/integrations/spotify/callback"

# Google Calendar — Configurar en Google Cloud Console
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/v1/integrations/google/callback"

# Google Fit — Mismo proyecto que Google Calendar
GOOGLE_FIT_CLIENT_ID=""

# ─── URLs ────────────────────────────────────────────────
API_URL="http://localhost:3001"
WEB_URL="http://localhost:5173"
